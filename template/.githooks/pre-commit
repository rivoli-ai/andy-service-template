# Pre-commit hook: scan staged files for secrets before committing.
#
# Install: ./scripts/setup-git-hooks.sh
# or:      git config core.hooksPath .githooks

set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# Patterns that indicate secrets (case-insensitive)
SECRET_PATTERNS=(
  'password\s*[:=]\s*"[^"]{4,}'
  'secret\s*[:=]\s*"[^"]{4,}'
  'api[_-]?key\s*[:=]\s*"[^"]{4,}'
  'private[_-]?key\s*[:=]\s*"[^"]{4,}'
  'access[_-]?token\s*[:=]\s*"[^"]{4,}'
  'bearer\s+[A-Za-z0-9\-_.]{20,}'
  'AKIA[0-9A-Z]{16}'
  'ghp_[A-Za-z0-9]{36}'
  'gho_[A-Za-z0-9]{36}'
  'sk-[A-Za-z0-9]{32,}'
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
  'mongodb(\+srv)?://[^/\s]+:[^@/\s]+@'
  'postgres(ql)?://[^/\s]+:[^@/\s]+@'
)

# Files to always skip
SKIP_PATTERNS="\.gitignore|\.md$|auth-seed\.sql|rbac-seed\.json|package-lock\.json|\.csproj$"

FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

for pattern in "${SECRET_PATTERNS[@]}"; do
  # Search staged file contents (not working tree)
  while IFS= read -r file; do
    # Skip known safe files
    if echo "$file" | grep -qE "$SKIP_PATTERNS"; then
      continue
    fi

    # Check staged content
    matches=$(git show ":$file" 2>/dev/null | grep -inE "$pattern" 2>/dev/null || true)
    if [[ -n "$matches" ]]; then
      echo -e "${RED}[SECRET DETECTED]${NC} $file"
      echo "$matches" | head -3 | sed 's/^/  /'
      FOUND=$((FOUND + 1))
    fi
  done <<< "$STAGED_FILES"
done

if [[ $FOUND -gt 0 ]]; then
  echo ""
  echo -e "${RED}Commit blocked: $FOUND potential secret(s) found.${NC}"
  echo "If these are intentional (dev defaults, examples), use:"
  echo "  git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}No secrets detected.${NC}"
exit 0
