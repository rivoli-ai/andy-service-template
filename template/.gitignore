# =============================================================================
# Andy Service Template — .gitignore
# Covers: .NET 8, Angular, Node, Docker, IDEs, certs, databases, coverage
# =============================================================================

# --- .NET Build ---
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
publish/

# --- .NET Core ---
project.lock.json
project.fragment.lock.json

# --- NuGet ---
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# --- MSBuild ---
*.binlog
[Bb]uild[Ll]og.*

# --- .NET User/IDE files ---
*.user
*.suo
*.cache
*.vspscc
*.vssscc
*.userprefs
*.pidb
*.DotSettings.user
.vs/

# --- Test Results & Coverage ---
[Tt]est[Rr]esult*/
TestResults/
TestResult.xml
*.trx
*.VisualState.xml
nunit-*.xml
CodeCoverage/
CoverageReport/
coverage/
coverage*
*.coverage
*.coveragexml

# --- Node / Angular ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
tmp/
.angular/
.cache/

# --- Environment ---
.env
.env.*
!.env.example
secrets.json

# --- appsettings (keep base + Development) ---
appsettings.*.json
!appsettings.json
!appsettings.Development.json

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~
~$*

# --- OS ---
.DS_Store
Thumbs.db
._*

# --- Docker ---
docker-compose.override.yml

# --- Certificates (keep .gitkeep and README only) ---
certs/*.crt
certs/*.pem
certs/*.cer
certs/*.key
certs/*.pfx
!certs/.gitkeep
!certs/README.md

# --- Database files ---
*.db
*.db-shm
*.db-wal
*.mdf
*.ldf

# --- Runtime data ---
/data/

# --- MkDocs build output ---
site/

# --- Claude / AI assistant ---
.claude/
