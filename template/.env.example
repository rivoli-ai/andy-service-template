# =============================================================================
# Andy service — environment variable reference
# =============================================================================
# This file documents every variable consumed by docker-compose.yml,
# scripts/run-dev.sh, scripts/run-embedded.sh, and the Angular build.
#
# DO NOT commit a real `.env` — it is generated by scripts/sync-dep-ports.sh
# from each dependency's config/registration.json. The script writes:
#   .env.dotnet    — host dev mode (dotnet run, deps on localhost)
#   .env.docker    — containerized mode (deps on host.docker.internal)
#   .env.embedded  — Conductor-bundled mode (deps via http://localhost:9100/<prefix>)
# and copies .env.docker to .env so `docker compose up` works zero-config.
#
# Usage:
#   ./scripts/sync-dep-ports.sh        # generate all three
#   ./scripts/sync-dep-ports.sh --check  # CI gate: fail if drift
#
# Override the sibling-repo lookup root (default: parent dir):
#   ANDY_SIBLING_ROOT=/path/to/repos ./scripts/sync-dep-ports.sh
# =============================================================================

# Which mode this .env was generated for. Informational only.
ANDY_RUNTIME_MODE=docker

# --- Cross-service URLs (canonical names, sourced from each dep's manifest) --
# .NET reads these via the `__`-separated mapping (AndyAuth__Authority etc.),
# performed inside docker-compose.yml / run-dev.sh / run-embedded.sh — never
# inside C# code.

# andy-auth — OAuth2/OIDC issuer. dockerHttps default 7001, dotnetHttps 5001.
ANDY_AUTH_AUTHORITY=https://host.docker.internal:7001

# andy-rbac — authorization API. dockerHttps default 7003, dotnetHttps 5003.
ANDY_RBAC_API_BASE_URL=https://host.docker.internal:7003

# andy-settings — centralized configuration API. dockerHttps default 7300, dotnetHttps 5300.
ANDY_SETTINGS_API_BASE_URL=https://host.docker.internal:7300

# --- This service's identity (sourced from local config/registration.json) ---
ANDY_AUTH_AUDIENCE=urn:__SERVICE_KEBAB__-api
ANDY_RBAC_APPLICATION_CODE=__SERVICE_KEBAB__
ANDY_SETTINGS_APPLICATION_CODE=__SERVICE_KEBAB__
ANDY_FRONTEND_AUTH_CLIENT_ID=__SERVICE_KEBAB__-web
